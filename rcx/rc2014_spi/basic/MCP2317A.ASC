100 REM ==============================
110 REM SPI via XIO and RCX
120 REM Designed with SPI Calls via
130 REM RCX library
140 REM MSC23S17 with GPIO A as output
150 REM and GPIO B as input
160 REM ==============================
170 CLS
180 DEFINT A,B,C,D,E,F,G,H,I,J,K,L
190 DIM K(3)
200 REM ==============================
210 _RCX ISINIT(A)
220 IF A=1 THEN _RCX DEINIT
230 _RCX INIT
240 REM ==============================
250 J=0
260 A=&H40:   REM MCP address
270 B=&H0:    REM IODIRA
280 C=&H1:    REM IODIRB
290 D=&H12:   REM GPIOA
300 E=&H13:   REM GPIOB
310 F=&H14:   REM OLATA
320 G=&H15:   REM OLATB
330 H=&HA:    REM IOCON
340 REM ==============================
350 _SPI INIT(&H10)
360 _SPI MODE(&H10,0,0,0)
380 REM ==============================
390 K(0) = A: K(1) = B: K(2) = 0
400 _SPI WRB(&H10,0,3,K(0))
410 REM ==============================
420 K(0) = A: K(1) = C: K(2) = &HFF
430 _SPI WRB(&H10,0,3,K(0))
440 REM ==============================
450 K(0) = A: K(1) = D: K(2) = J
460 _SPI WRB(&H10,0,3,K(0))
470 REM ==============================
480 K(0) = A+1: K(1) = E: K(2) = 0
490 _SPI RDH(&H10,0,2,1,K(0))
500 I = K(2)
510 REM ==============================
520 PRINT"OUT: ",HEX$(J),"IN: ",HEX$(I)
530 J=J+1
540 IF J=256 THEN J=0
550 GOTO 450
