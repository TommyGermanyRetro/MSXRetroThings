<text x="12.3825" y="11.43" size="1.27" layer="25" font="vector" rot="SR90">19.09.2025</text>
<text x="2.2225" y="24.13" size="1.27" layer="25" font="vector" rot="SR90">msx_io_expander_slot.brd</text>
<wire x1="0" y1="22.225" x2="0" y2="80.01" width="0.254" layer="20"/>
<wire x1="0" y1="80.01" x2="102.87" y2="80.01" width="0.254" layer="20"/>
<wire x1="102.87" y1="80.01" x2="102.87" y2="9.525" width="0.254" layer="20"/>
<text x="97.4725" y="37.465" size="0.6096" layer="25" font="vector" rot="R90">I/O-Adressraum Wiesnertec
Device-ID: 192 / 0xC0
0x40        = Switched IO Manufaktor
0x41        = Get Interruptchannel
0x42        = /CS-PIC A0=0
0x43        = /CS-PIC A0=1
0x44        = INTA-READ
0x45        = IM2-READ
0x46        = Set I/O-Address
0x47        = READ/WRITE I/O
0x48..0x4F   = n.c.</text>
<text x="12.065" y="73.9775" size="1.016" layer="25" font="vector" rot="SR180">IOEN</text>
<text x="6.0325" y="73.9775" size="1.016" layer="25" font="vector" rot="SR180">+5V</text>
<text x="18.0975" y="73.9775" size="1.016" layer="25" font="vector" rot="SR180">INTEN</text>
<text x="35.56" y="73.025" size="1.016" layer="25" font="vector" rot="SR90">PROG</text>
<text x="21.9075" y="73.025" size="1.016" layer="25" font="vector" rot="SR90">WORK</text>
</plain>
