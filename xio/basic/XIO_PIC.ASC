10 REM **********************************
20 REM PIC test routine
30 REM **********************************
100  CLEAR 200,&HD000
110 DEFINT A, B
120 A=0:B=0:C=0
130 CLS
140 REM XIO start
150 _XIO INIT(A)
160 PRINT "[XIO] is installed"
170 REM ASM-Routine set
180 AD = &HD000
190 RESTORE 630
200 READ A$
210 IF A$<>"END" THEN POKE AD,VAL("&H"+A$):AD=AD+1:GOTO 200
220 _XIO SET ADDR(0,&HD000)
230 REM Set MASK for PIC &Hxx00 ... &HxxFF
240 B = &H1
250 _XIO SET MASK(B)
260 PRINT "[XIO] mask for PIC is set to &H";:PRINT HEX$(B)
270 PRINT "<SPACE> ends programme, waiting for INT"
280 IF (A AND &H1)   = &H1   THEN GOSUB 390
290 IF (A AND &H2)   = &H2   THEN GOSUB 420
300 IF (A AND &H4)   = &H4   THEN GOSUB 450
310 IF (A AND &H8)   = &H8   THEN GOSUB 480
320 IF (A AND &H10)   = &H10   THEN GOSUB 510
330 IF (A AND &H20)   = &H20   THEN GOSUB 540
340 IF (A AND &H40)   = &H40   THEN GOSUB 570
350 IF (A AND &H80)   = &H80   THEN GOSUB 600
360 IF INKEY$ <>" " GOTO 280
370 _XIO DEINIT
380 END
390 PRINT "Here channel 0 ... <SPACE> ends programme, waiting for INT"
400 A = (A AND &HFE)
410  RETURN
420 PRINT "Here channel 1 ... <SPACE> ends programme, waiting for INT"
430 A = (A AND &HFD)
440 RETURN
450 PRINT "Here channel 2 ... <SPACE> ends programme, waiting for INT"
460 A = (A AND &HFB)
470 RETURN
480 PRINT "Here channel 3 ... <SPACE> ends programme, waiting for INT"
490 A = (A AND &HF7)
500 RETURN
510 PRINT "Here channel 4 ... <SPACE> ends programme, waiting for INT"
520 A = (A AND &HEF)
530 RETURN
540 PRINT "Here channel 5 ... <SPACE> ends programme, waiting for INT"
550 A = (A AND &HDF)
560 RETURN
570 PRINT "Here channel 6 ... <SPACE> ends programme, waiting for INT"
580 A = (A AND &HBF)
590 RETURN
600 PRINT "Here channel 7 ... <SPACE> ends programme, waiting for INT"
610 A = (A AND &H7F)
620 RETURN
630 DATA 3E,41,CD,A2,00
640 DATA 3E,53,CD,A2,00
650 DATA 3E,4D,CD,A2,00
660 DATA 3E,20,CD,A2,00
670 DATA 3E,43,CD,A2,00
680 DATA 3E,68,CD,A2,00
690 DATA 3E,3A,CD,A2,00
700 DATA 3E,20,CD,A2,00
710 DATA 3E,30,CD,A2,00
720 DATA 3E,0A,CD,A2,00
730 DATA 3E,0D,CD,A2,00
740 DATA C9,END
