10  REM ==============================
11  REM ADS1220 via standard XIO cmds
12  REM Reads all 4 channels and save
13  REM them in a float variable
16  REM ==============================
100 CLS
101 REM ==============================
110 DEFINT A,I,J:A=0:I=0:J=0
111 REM A: IO data
112 REM J: Channel 0..3
113 REM I: Byte 0..3 of varptr(B)
114 REM ==============================
120 DEFSNG B:B=0!
121 REM B: Result of measure
122 REM ==============================
130 _XIO OUT(&H20,&H4)
140 _XIO OUT(&H21,&H80)
150 _XIO OUT(&H20,&H9)
160 _XIO OUT(&H21,&H80)
210 FOR J=0 TO 3
220  FL = VARPTR(B)
221  _XIO OUT(&H21,J)
230  FOR I=0 TO 3
240   _XIO INP(&H23,A)
250   POKE FL,A
260   FL=FL+1
270  NEXT
280  PRINT B;:PRINT" ";:
285  J=J+1
290 NEXT
300 PRINT
310 GOTO 130
