1  REM ***************************
2  REM *** Test of 8254 card   ***
3  REM *** Connect OUT TIMER 0 ***
4  REM *** with CLK TIMER 1    ***
5  REM *************************** 
10 CLS
20 DEFINT A,B
30 _RCX ISINIT(A)
40 IF A=1 THEN _RCX DEINIT
50 _RCX INIT
60 _TIMER INIT(&H8)
70 _TIMER RES GATE(&H8,7)
80 _TIMER 0 WR(&H8,&HFFFF)
90 _TIMER SET GATE(&H8,1)
120 _TIMER SET GATE(&H8,2)
130 _TIMER RES GATE(&H8,2)
131 _TIMER 0 RD(&H8,A)
132 PRINT HEX$(A)
140 GOTO 120