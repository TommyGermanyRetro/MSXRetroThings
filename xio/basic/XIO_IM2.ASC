10 REM **********************************
20 REM IM2 test routine
30 REM Uses SC103 as DUT
40 REM **********************************
50 CLEAR 200,&HD000
100 DEFINT A, B, C
110 A=0:B=0:C=0
120 CLS
130 REM PIO via RC2014 SC103
140 REM PORT A as OUTPUT
150 _XIO OUT(&H82,&HF)
160 REM PORT A = 0
170 _XIO OUT(&H80,0)
180 REM PORT B as MODE 3 and PB0 as Input
190 _XIO OUT(&H83,&HCF)
200 _XIO OUT(&H83,1)
210 REM PORT B INT-Vektor 0,2,4...14
220 _XIO OUT(&H83,0)
230 REM PORT B INT-Controll via PB0
240 _XIO OUT(&H83,&HB7)
250 _XIO OUT(&H83,254)
260 _XIO INIT(A)
270 PRINT "[XIO] is installed"
271 REM ASM-Routine set
272 AD = &HD000
273 RESTORE 630
274 READ A$
275 IF A$<>"END" THEN POKE AD,VAL("&H"+A$):AD=AD+1:GOTO 274
276 _XIO SET ADDR(8,&HD000)
280 REM Set MASK for IM2 &H00xx ... &HFFxx
290 C = &HFF00
300 _XIO SET MASK(C)
310 PRINT "[XIO] mask for IM2 is set to &H";:PRINT HEX$(C)
320 PRINT "<SPACE> ends programme, waiting for INT"
330 IF (A AND &H100) = &H100 THEN GOSUB 480
340 IF (A AND &H200) = &H200 THEN GOSUB 510
350 IF (A AND &H400) = &H400 THEN GOSUB 540
360 IF (A AND &H800) = &H800 THEN GOSUB 570
370 IF (A AND &H1000) = &H1000 THEN GOSUB 600
380 IF (A AND &H2000) = &H2000 THEN GOSUB 630
390 IF (A AND &H4000) = &H4000 THEN GOSUB 660
400 IF (A AND &H8000) = &H8000 THEN GOSUB 690
410 REM Gebe 0/1 auf PORT A PA0 aus
420 _XIO OUT(&H80,B)
430 REM Toggle Bit fuer PORT A PA0
440 IF B=0 THEN B=1 ELSE B=0
450 IF INKEY$ <>" " GOTO 330
460 _XIO DEINIT
470 END
480 PRINT "Here channel 0 ... <SPACE> ends programme, waiting for INT"
490 A = (A AND &HFE00)
500  RETURN
510 PRINT "Here channel 1 ... <SPACE> ends programme, waiting for INT"
520 A = (A AND &HFD00)
530 RETURN
540 PRINT "Here channel 2 ... <SPACE> ends programme, waiting for INT"
550 A = (A AND &HFB00)
560 RETURN
570 PRINT "Here channel 3 ... <SPACE> ends programme, waiting for INT"
580 A = (A AND &HF700)
590 RETURN
600 PRINT "Here channel 4 ... <SPACE> ends programme, waiting for INT"
610 A = (A AND &HEF00)
620 RETURN
630 PRINT "Here channel 5 ... <SPACE> ends programme, waiting for INT"
640 A = (A AND &HDF00)
650 RETURN
660 PRINT "Here channel 6 ... <SPACE> ends programme, waiting for INT"
670 A = (A AND &HBF00)
680 RETURN
690 PRINT "Here channel 7 ... <SPACE> ends programme, waiting for INT"
700 A = (A AND &H7F00)
710 RETURN
830 DATA 3E,41,CD,A2,00
840 DATA 3E,53,CD,A2,00
850 DATA 3E,4D,CD,A2,00
860 DATA 3E,20,CD,A2,00
870 DATA 3E,43,CD,A2,00
880 DATA 3E,68,CD,A2,00
890 DATA 3E,3A,CD,A2,00
900 DATA 3E,20,CD,A2,00
910 DATA 3E,30,CD,A2,00
920 DATA 3E,0A,CD,A2,00
930 DATA 3E,0D,CD,A2,00
940 DATA ED,4D,END
