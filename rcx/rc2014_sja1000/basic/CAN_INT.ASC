100 REM **********************************
110 REM RC2014 CAN CARD
120 REM Example with BASIC code only
130 REM Uses Acceptance code and mask
140 REM Works for medium CAN traffic
145 REM Connection to CS3 from maerklin
150 REM **********************************
160 CLS
170 REM ----------------------------------
180 REM Variable usage
190 REM A = Read Message Count
200 REM B(12) = CAN Message
210 REM C = FOR-NEXT-Index
220 REM D = INIT-Flag
230 REM E(7) = Acceptance code & mask
240 REM F = INT-Channel
250 REM G(12) = CAN Message TX
260 REM ----------------------------------
270 REM ----------------------------------
280 REM Check XIO and install
290 REM ----------------------------------
300 DEFINT D,F:D=0:F=0
310 _XIO ISINIT(D)
320 IF D>0 THEN _XIO DEINIT
330 _XIO INIT(F)
340 REM ----------------------------------
350 REM Check RCX and install
360 REM ----------------------------------
370 D=0
380 _RCX ISINIT(D)
390 IF D>0 THEN _RCX DEINIT
400 _RCX INIT
410 REM ----------------------------------
420 REM Dim Variables
430 REM ----------------------------------
440 DEFINT A,B,C,E,G
450 DIM B(12):DIM G(12)
460 DIM E(7)
470 RESTORE 890
480 G(0)=&H86:G(1)=0:G(2)=&HB1:G(3)=&HDA:G(4)=&HE8:G(5)=0:G(6)=0
490 FOR C = 0 TO 7
500 READ E(C)
510 NEXT
520 REM ----------------------------------
530 REM Install SJA1000 at IO = 2 with ACC E(x)
540 REM ----------------------------------
550 _CAN INIT(2,E(0))
560 REM ----------------------------------
570 REM Prepare CAN Interrupt
580 REM ----------------------------------
590 _CAN GET ADDR(2,D)
600 _XIO SET ADDR(3,D)
610 _XIO SET MASK(8)
620 REM ----------------------------------
630 REM Check SJA1000 for new messages to read
640 REM ----------------------------------
650 _CAN CHECK(2,A)
670 IF A>0 THEN GOSUB 740
680 A$=INKEY$
681 IF A$=CHR$(27) THEN GOTO 2000
690 IF A$="1" THEN GOSUB 900
700 GOTO 650
710 REM ----------------------------------
720 REM Prompt received CAN message
730 REM ----------------------------------
740 LOCATE 0,0
750 PRINT"RX: "
760 LOCATE 4,0
770 _CAN RX(2,B(0))
780 FOR C=0 TO 12
790 IF B(C)<16 THEN PRINT "0";:
800 PRINT HEX$(B(C));:PRINT" ";
810 NEXT
820 PRINT
830 RETURN
840 REM ----------------------------------
850 REM Acceptance code & mask
860 REM ACR.0,ACR.1,ACR.2,ACR.3
870 REM AMR.0,AMR.1,AMR.2,AMR.3
880 REM ----------------------------------
890 DATA &HF0,&HB7,&HFF,&HFF,&HF0,&H07,&HFF,&HFF
900 LOCATE 1,3
910 PRINT "                "
920 INPUT"ADDR:";A$
930 B$="&H"+LEFT$(A$,4)
940 A$="&H"+RIGHT$(A$,1)
950 C=VAL(B$)
960 G(0)=&H86:G(1)=0:G(2)=&HB1:G(3)=&HDA:G(4)=&HE8:G(5)=0:G(6)=0
970 G(7)=C/256
980 G(8)=(C AND &HF)
990 G(9)=VAL(A$)
1000 G(10)=1
1010 _CAN TX(2,G(0))
1020 G(10)=0
1030 _CAN TX(2,G(0))
1090 RETURN
2000 _XIO DEINIT
2010 _RCX DEINIT
2020 END
