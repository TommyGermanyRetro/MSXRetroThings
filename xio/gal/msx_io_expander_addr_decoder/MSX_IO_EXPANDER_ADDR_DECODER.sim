%FIELD
%END

%EQUATION
0x40_RD =>
    !A0 & !A1 & !A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & M1 & !RD

0x40_WR =>
    !A0 & !A1 & !A2 & !A3 & !A4 & !A5 & !Ax & !IORQ & M1 & !WR

0x4x =>
    !A4 & !A5 & !Ax & !IOEN & !IORQ & M1

ALE =>
    !A0 & A1 & A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & M1 & !WR

!GETINT =>
    A0 & !A1 & !A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & M1

IM2RD =>
    A0 & !A1 & A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & M1 & !RD

!INTA =>
    !A0 & !A1 & A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & M1 & !RD

IO =>
    A0 & A1 & A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & M1

!M1b =>
    !M1 & !RD
  # A0 & !A1 & A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & !RD

!PIC =>
    A1 & !A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & M1

RC2014 =>
    A0 & A1 & A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & M1
  # A0 & A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & M1 & !RD

!RDb =>
    !M1 & !RD
  # A0 & A1 & A2 & !A3 & !A4 & !A5 & !Ax & !IOEN & !IORQ & !RD

0x40_RD.oe  =>
    1 

0x40_WR.oe  =>
    1 

0x4x.oe  =>
    1 

ALE.oe  =>
    1 

GETINT.oe  =>
    1 

INTA.oe  =>
    1 

