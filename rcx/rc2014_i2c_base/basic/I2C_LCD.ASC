100 REM *************************
110 REM *** SEEED I2C LCD     ***
120 REM *************************
130 _RCX INIT
140 _I2C INIT(0)
150 DEFINT A,B,C,D,E
160 A = &H7C
170 C = &H40
180 D = &H80
190 DIM B(20)
200 B(0) = D
210 B(1) = &H28
220 _I2C WRB(0,A,2,B(0))
230 _I2C WRB(0,A,2,B(0))
240 _I2C WRB(0,A,2,B(0))
250 _I2C WRB(0,A,2,B(0))
260 B(1) = &H1
270 _I2C WRB(0,A,2,B(0))
280 B(1) = &HF
290 _I2C WRB(0,A,2,B(0))
300 A$="MSXRetroThings"
310 E = LEN(A$)
320 FOR F = 1 TO E
330 B(F) = ASC(MID$(A$,F))
340 NEXT
350 B(0) = C
360 E = E + 1
370 _I2C WRB(0,A,E,B(0))
380 _RCX DEINIT
