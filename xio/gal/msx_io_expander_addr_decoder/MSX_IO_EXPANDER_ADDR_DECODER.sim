PIN   4 =  A5 
PIN  22 =  ALE 
PIN   3 =  Ax 
PIN  23 =  GETINT 
PIN  21 =  INTA 
PIN   1 =  IOEN 
PIN  10 =  IORQ 
PIN  11 =  M1 
PIN  17 =  M1b 
PIN  20 =  PIC 
